{
  "uid": "kvwarden-overview-v1",
  "title": "KVWarden — Launch-day overview",
  "description": "Three-panel launch overview. Sits alongside dashboards/kvwarden-fairness.json which covers the per-tenant fairness story in depth. This one is the first thing to open when asked 'is it healthy right now?'",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["kvwarden", "overview", "launch"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(kvwarden_tenant_ttft_seconds_bucket, model)",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "TTFT p99 per tenant (noisy-neighbor alert)",
      "description": "p99 time-to-first-token, broken out by tenant. If one tenant's line climbs while another stays flat, you have a starvation event. This is the metric the launch claim 'quiet within 1.35x of solo' lives or dies on.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (tenant, le) (rate(kvwarden_tenant_ttft_seconds_bucket{model=~\"$model\"}[1m])))",
          "legendFormat": "p99 — {{tenant}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"lineWidth": 2, "fillOpacity": 5},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.2},
              {"color": "red", "value": 1.0}
            ]
          }
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests per second per tenant",
      "description": "Live RPS broken out by tenant. Useful for correlating noisy-neighbor panels: a tenant's p99 spike at t=X should coincide with either their own RPS spike (self-inflicted) or another tenant's (contention).",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tenant) (rate(kvwarden_requests_total{model=~\"$model\"}[1m]))",
          "legendFormat": "{{tenant}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineWidth": 1.5, "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"]},
        "tooltip": {"mode": "multi"}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Admission queue depth + in-flight",
      "description": "Depth of the admission queue and count of requests currently forwarded to the engine. When queue_depth rises above zero, KVWarden is actively shaping traffic to keep the engine below its saturation cliff. If depth stays pinned at queue_size (default 1024) and admission_rejected_total{reason=\"queue_full\"} is climbing, you're shedding load — scale the engine or raise max_concurrent.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9},
      "targets": [
        {
          "refId": "A",
          "expr": "kvwarden_admission_queue_depth",
          "legendFormat": "queue depth"
        },
        {
          "refId": "B",
          "expr": "kvwarden_admission_in_flight",
          "legendFormat": "in-flight"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 1.5, "fillOpacity": 10}
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      }
    }
  ]
}
